APP_ENV=local
APP_NAME=inventory-manager-api
HTTP_PORT=8080
LOG_LEVEL=info
APP_BASE_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

DATABASE_URL=postgres://postgres:postgres@localhost:5432/inventory_manager?sslmode=disable
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m

APP_MODE=local
AUTH_MODE=none
RBAC_MODE=dry_run
JWT_VERIFIER=local
LOCAL_AUTH_TOKENS=
OIDC_EXPECTED_ISSUER=
OIDC_EXPECTED_AUDIENCE=
OIDC_JWKS_URL=
JWT_SIGNING_ALGORITHMS=RS256
OIDC_REQUIRE_EMAIL_VERIFIED=false
STORAGE_MODE=local
ARTIFACTS_DIR=./artifacts
CLOUD_STORAGE_BUCKET=your-artifact-bucket-name

# Procurement external sync.
# Pub/Sub push can target POST /api/v1/procurement/webhooks/pubsub.
PROCUREMENT_WEBHOOK_SECRET=
RAKURAKU_VIEW_API_URL=https://your-account.rakurakuhanbai.jp/your-path/apirecord/view/version/v1
RAKURAKU_API_TOKEN=
RAKURAKU_RESPONSE_TYPE=1
RAKURAKU_PROCUREMENT_DB_SCHEMA_ID=

OCR_PROVIDER=vertex_ai
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_AI_LOCATION=asia-northeast1
GEMINI_MODEL=gemini-3-flash-preview
# Optional for local development when not using gcloud ADC.
# Leave empty if you authenticate with: gcloud auth application-default login
# Cloud Run should use its attached runtime service account.
GOOGLE_APPLICATION_CREDENTIALS=
OCR_STORAGE_BUCKET=your-artifact-bucket-name
